<?xml version='1.0' encoding='utf-8'?>
<robot name="arm">
	<link name="world" />
	<link name="base_link">
		<visual>
			<geometry>
				<cylinder length="0.05" radius="0.1" />
			</geometry>
			<material name="silver">
				<color rgba="0.75 0.75 0.75 1" />
			</material>
			<origin rpy="0 0 0" xyz="0 0 0.025" /> 
		</visual>
	<collision><geometry>
				<cylinder length="0.05" radius="0.1" />
			</geometry><origin rpy="0 0 0" xyz="0 0 0.025" /></collision></link>
	<joint name="fixed" type="fixed">
		<parent link="world" />
		<child link="base_link" />
	</joint>

	<link name="torso">
		<visual>		
			<geometry>
				<cylinder length="0.5" radius="0.05" />
			</geometry>
			<material name="silver">
				<color rgba="0.75 0.75 0.75 1" />
			</material>
			<origin rpy="0 0 0" xyz="0.0 0.0 0.25" />
		</visual>
	<collision><geometry>
				<cylinder length="0.5" radius="0.05" />
			</geometry><origin rpy="0 0 0" xyz="0.0 0.0 0.25" /></collision></link>
	<joint name="hip" type="continuous">
		<axis xyz="0 0 1" />
		<parent link="base_link" />
		<child link="torso" />
		<origin rpy="0 0 0" xyz="0 0 0.05" />
	</joint>

	<link name="upper_arm">
		<visual>
			<geometry>
				<cylinder length="0.4" radius="0.05" />
			</geometry>
			<material name="silver" />
			<origin rpy="0 0 0" xyz="0 0 0.2" />
		</visual>
	<collision><geometry>
				<cylinder length="0.4" radius="0.05" />
			</geometry><origin rpy="0 0 0" xyz="0 0 0.2" /></collision></link>
	<joint name="shoulder" type="revolute">
		<axis xyz="0 1 0" />
		<limit velocity="1.0" effort="30.0" upper="0.6981" lower="-1.5708" />
		<parent link="torso" />
		<child link="upper_arm" />
		<origin rpy="0 1.5708 0" xyz="0.0 -0.1 0.45" />
	</joint>

	<link name="lower_arm">
		<visual>
			<geometry>
				<cylinder length="0.4" radius="0.05" />
			</geometry>
			<material name="silver" />
			<origin rpy="0 0 0" xyz="0 0 0.2" />
		</visual>
	<collision><geometry>
				<cylinder length="0.4" radius="0.05" />
			</geometry><origin rpy="0 0 0" xyz="0 0 0.2" /></collision></link>
	<joint name="elbow" type="revolute">
		<axis xyz="0 1 0" />
		<limit velocity="1.0" effort="30.0" upper="1.5708" lower="-1.5708" />
		<parent link="upper_arm" />
		<child link="lower_arm" />
		<origin rpy="0 0 0" xyz="0.0 0.1 0.35" />
	</joint>

	<link name="hand">
		<visual>
			<geometry>
				<box size="0.05 0.05 0.05" />
			</geometry>
			<material name="silver" />
		</visual>
	<collision><geometry>
				<box size="0.05 0.05 0.05" />
			</geometry></collision></link>
	<joint name="wrist" type="continuous">
		<axis xyz="0 1 0" />
		<parent link="lower_arm" />
		<child link="hand" />
		<origin rpy="0 0 0" xyz="0.0 0.0 0.425" />
	</joint>

	<link name="left_gripper_base">
		<visual>
			<geometry>
				<box size="0.005 0.005 0.02" />
			</geometry>
			<material name="silver" />
		</visual>
	<collision><geometry>
				<box size="0.005 0.005 0.02" />
			</geometry></collision></link>
	<joint name="l_g_base" type="revolute">
		<axis xyz="1 0 0" />
		<limit velocity="1.0" effort="30.0" lower="0" upper="0.5236" />
		<origin rpy="-0.9162 0 0" xyz="0 0.02 0.035" />
		<parent link="hand" />
		<child link="left_gripper_base" />
	</joint>

	<link name="right_gripper_base">
		<visual>
			<geometry>
				<box size="0.005 0.005 0.02" />
			</geometry>
			<material name="silver" />
		</visual>
	<collision><geometry>
				<box size="0.005 0.005 0.02" />
			</geometry></collision></link>
	<joint name="r_g_base" type="revolute">
		<axis xyz="1 0 0" />
		<limit velocity="1.0" effort="100.0" upper="0" lower="-0.5236" />
		<origin rpy="0.9162 0 0" xyz="0 -0.02 0.035" />
		<parent link="hand" />
		<child link="right_gripper_base" />
	</joint>

	<link name="left_gripper_finger">
		<visual>
			<geometry>
				<box size="0.008 0.008 0.05" />
			</geometry>
			<material name="silver" />
		</visual>
	<collision><geometry>
				<box size="0.008 0.008 0.05" />
			</geometry></collision></link>
	<joint name="l_g_finger" type="fixed">
		<origin rpy="0.3926 0 0" xyz="0 -0.01 0.03" />
		<parent link="left_gripper_base" />
		<child link="left_gripper_finger" />
	</joint>

	<link name="right_gripper_finger">
		<visual>
			<geometry>
				<box size="0.008 0.008 0.05" />
			</geometry>
			<material name="silver" />
		</visual>
	<collision><geometry>
				<box size="0.008 0.008 0.05" />
			</geometry></collision></link>
	<joint name="r_g_finger" type="fixed">
		<origin rpy="-0.3926 0 0" xyz="0 0.01 0.03" />
		<parent link="right_gripper_base" />
		<child link="right_gripper_finger" />
	</joint>
	<ros2_control name="FakeSystem" type="system">
		<hardware>
			<plugin>mock_components/GenericSystem</plugin>
		</hardware>
		<joint name="hip">
			<command_interface name="position"/>
			<state_interface name="position"><param name="initial_value">0.0</param></state_interface>
			<state_interface name="velocity"/>
		</joint>
		<joint name="shoulder">
			<command_interface name="position"/>
			<state_interface name="position"><param name="initial_value">-1.5708</param></state_interface>
			<state_interface name="velocity"/>
		</joint>
		<joint name="elbow">
			<command_interface name="position"/>
			<state_interface name="position"><param name="initial_value">0.0</param></state_interface>
			<state_interface name="velocity"/>
		</joint>
		<joint name="wrist">
			<command_interface name="position"/>
			<state_interface name="position"><param name="initial_value">0.0</param></state_interface>
			<state_interface name="velocity"/>
		</joint>
		<joint name="l_g_base">
			<command_interface name="position"/>
			<state_interface name="position"><param name="initial_value">0.0</param></state_interface>
			<state_interface name="velocity"/>
		</joint>
		<joint name="r_g_base">
			<command_interface name="position"/>
			<state_interface name="position"><param name="initial_value">0.0</param></state_interface>
			<state_interface name="velocity"/>
		</joint>
	</ros2_control>
</robot>